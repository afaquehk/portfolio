<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 450" fill="none">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="800" y2="450" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#4b556d"/>
      <stop offset="0.52" stop-color="#5f6b7a"/>
      <stop offset="1" stop-color="#becbda"/>
    </linearGradient>
    <linearGradient id="heroFade" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#0f172a" stop-opacity="0.36"/>
      <stop offset="1" stop-color="#e6edf8" stop-opacity="0.1"/>
    </linearGradient>
    <linearGradient id="navGlass" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#ffffff" stop-opacity="0.96"/>
      <stop offset="1" stop-color="#eef2f7" stop-opacity="0.92"/>
    </linearGradient>
    <linearGradient id="panelGlass" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#ffffff" stop-opacity="0.92"/>
      <stop offset="1" stop-color="#f6f8fb" stop-opacity="0.86"/>
    </linearGradient>
    <linearGradient id="cta" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0c7281"/>
      <stop offset="1" stop-color="#1493a0"/>
    </linearGradient>
    <filter id="blur24" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="12"/>
    </filter>
    <filter id="blur8" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="4"/>
    </filter>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="160%">
      <feDropShadow dx="0" dy="10" stdDeviation="14" flood-color="#1f2937" flood-opacity="0.18"/>
    </filter>
  </defs>

  <rect width="800" height="450" fill="url(#bg)"/>
  <rect width="800" height="450" fill="url(#heroFade)"/>

  <ellipse cx="196" cy="51" rx="170" ry="94" fill="#374151" fill-opacity="0.18" filter="url(#blur24)"/>
  <ellipse cx="696" cy="330" rx="188" ry="104" fill="#d7e1ef" fill-opacity="0.55" filter="url(#blur24)"/>

  <g opacity="0.72" filter="url(#blur8)">
    <circle cx="401" cy="103" r="10" fill="#0f172a"/>
    <path d="M404 113L392 200L415 201L410 117Z" fill="#111827"/>
    <path d="M396 164L343 226L360 236L412 182Z" fill="#1f2937"/>
    <path d="M415 181L513 220L503 237L404 196Z" fill="#0f172a"/>
    <path d="M351 224C323 229 300 247 288 276C275 308 280 341 303 358C332 379 376 374 403 345C428 320 432 279 413 251C397 228 374 220 351 224Z" fill="#111827"/>
    <path d="M543 237C512 238 483 255 471 283C457 316 465 353 491 369C520 387 566 379 593 348C618 319 620 277 599 252C585 241 563 236 543 237Z" fill="#111827"/>
    <circle cx="344" cy="301" r="74" stroke="#0f172a" stroke-width="15"/>
    <circle cx="541" cy="308" r="78" stroke="#0f172a" stroke-width="15"/>
    <path d="M360 242L466 243L520 305" stroke="#111827" stroke-width="17" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M455 245L426 302L351 303" stroke="#111827" stroke-width="16" stroke-linecap="round" stroke-linejoin="round"/>
    <rect x="440" y="215" width="90" height="18" rx="9" fill="#d1d5db"/>
    <rect x="276" y="215" width="86" height="13" rx="6.5" fill="#d1d5db"/>
  </g>

  <rect x="42" y="18" width="716" height="54" rx="16" fill="url(#navGlass)" stroke="#d9e0e8" filter="url(#shadow)"/>

  <circle cx="68" cy="45" r="15" fill="#111827"/>
  <circle cx="68" cy="45" r="11.5" stroke="#d4af37" stroke-width="2.8"/>
  <text x="58" y="49" fill="#d4af37" font-family="Arial, sans-serif" font-size="10" font-weight="700">RW</text>

  <text x="96" y="52" fill="#182033" font-family="Arial, sans-serif" font-size="18" font-weight="700">Royal</text>
  <text x="152" y="52" fill="#d6a92b" font-family="Arial, sans-serif" font-size="18" font-weight="700">Wheels</text>

  <text x="254" y="51" fill="#283244" font-family="Arial, sans-serif" font-size="10.5" font-weight="600">Home</text>
  <text x="312" y="51" fill="#283244" font-family="Arial, sans-serif" font-size="10.5" font-weight="600">Bikes</text>
  <text x="366" y="51" fill="#283244" font-family="Arial, sans-serif" font-size="10.5" font-weight="600">Cars</text>
  <text x="423" y="51" fill="#283244" font-family="Arial, sans-serif" font-size="10.5" font-weight="600">My Bookings</text>

  <rect x="531" y="28" width="107" height="26" rx="13" fill="#f7f9fc" stroke="#e5e7eb"/>
  <text x="542" y="45" fill="#a0a6b2" font-family="Arial, sans-serif" font-size="10.5">e.g. BMW X</text>
  <circle cx="627" cy="41" r="6" stroke="#9aa3af" stroke-width="1.5"/>
  <path d="M631 45L636 50" stroke="#9aa3af" stroke-width="1.5" stroke-linecap="round"/>

  <rect x="646" y="28" width="42" height="26" rx="10" fill="#eef2f7" stroke="#c7cfd9"/>
  <text x="656" y="45" fill="#1f2937" font-family="Arial, sans-serif" font-size="10.5" font-weight="700">Admin</text>

  <rect x="695" y="28" width="41" height="26" rx="10" fill="url(#cta)"/>
  <text x="706" y="45" fill="#ffffff" font-family="Arial, sans-serif" font-size="10.5" font-weight="700">Login</text>

  <rect x="276" y="126" width="248" height="20" rx="10" fill="#d7dde6" fill-opacity="0.28" stroke="#eef2f7" stroke-opacity="0.55"/>
  <text x="289" y="139" fill="#eef3f8" font-family="Arial, sans-serif" font-size="9.2" letter-spacing="0.4">FAST BOOKING. TRUSTED PARTNERS. PREMIUM EXPERIENCE.</text>

  <text x="130" y="184" fill="#ffffff" font-family="Arial, sans-serif" font-size="44" font-weight="700">Find the right</text>
  <text x="369" y="184" fill="#d7a92f" font-family="Arial, sans-serif" font-size="44" font-weight="700">car</text>
  <text x="448" y="184" fill="#ffffff" font-family="Arial, sans-serif" font-size="44" font-weight="700">or</text>
  <text x="493" y="184" fill="#d7a92f" font-family="Arial, sans-serif" font-size="44" font-weight="700">bike</text>
  <text x="595" y="184" fill="#ffffff" font-family="Arial, sans-serif" font-size="44" font-weight="700">for your</text>
  <text x="346" y="242" fill="#ffffff" font-family="Arial, sans-serif" font-size="44" font-weight="700">next ride</text>

  <text x="220" y="281" fill="#edf2f7" font-family="Arial, sans-serif" font-size="16">Choose from verified rental partners across your city and book in minutes.</text>

  <rect x="116" y="303" width="557" height="52" rx="16" fill="url(#panelGlass)" filter="url(#shadow)"/>

  <rect x="126" y="312" width="162" height="34" rx="11" fill="#eef2f9"/>
  <text x="138" y="326" fill="#5a6373" font-family="Arial, sans-serif" font-size="8.7" font-weight="700">VEHICLE TYPE</text>
  <text x="139" y="338" fill="#1f2937" font-family="Arial, sans-serif" font-size="10.8">Select vehicle type</text>
  <path d="M273 333L277 337L281 333" stroke="#1f2937" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>

  <rect x="294" y="312" width="154" height="34" rx="11" fill="#eef2f9"/>
  <text x="306" y="326" fill="#5a6373" font-family="Arial, sans-serif" font-size="8.7" font-weight="700">PICK-UP DATE</text>
  <text x="307" y="338" fill="#3f4756" font-family="Arial, sans-serif" font-size="10.8">dd-mm-yyyy</text>
  <rect x="432" y="325" width="8" height="10" rx="1.3" stroke="#1f2937" stroke-width="1.3"/>
  <path d="M434 322V327M438 322V327M432 329H440" stroke="#1f2937" stroke-width="1.2" stroke-linecap="round"/>

  <rect x="454" y="312" width="154" height="34" rx="11" fill="#eef2f9"/>
  <text x="466" y="326" fill="#5a6373" font-family="Arial, sans-serif" font-size="8.7" font-weight="700">RETURN DATE</text>
  <text x="467" y="338" fill="#3f4756" font-family="Arial, sans-serif" font-size="10.8">dd-mm-yyyy</text>
  <rect x="592" y="325" width="8" height="10" rx="1.3" stroke="#1f2937" stroke-width="1.3"/>
  <path d="M594 322V327M598 322V327M592 329H600" stroke="#1f2937" stroke-width="1.2" stroke-linecap="round"/>

  <rect x="615" y="312" width="55" height="34" rx="11" fill="url(#cta)"/>
  <text x="626" y="335" fill="#ffffff" font-family="Arial, sans-serif" font-size="12" font-weight="700">Search</text>

  <g opacity="0.86">
    <rect x="202" y="370" width="122" height="39" rx="12" fill="#d8dfe7" fill-opacity="0.18" stroke="#f8fafc" stroke-opacity="0.35"/>
    <rect x="334" y="370" width="122" height="39" rx="12" fill="#d8dfe7" fill-opacity="0.18" stroke="#f8fafc" stroke-opacity="0.35"/>
    <rect x="466" y="370" width="122" height="39" rx="12" fill="#d8dfe7" fill-opacity="0.18" stroke="#f8fafc" stroke-opacity="0.35"/>

    <text x="259" y="392" fill="#ffffff" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" font-weight="700">11</text>
    <text x="259" y="404" fill="#eef2f7" font-family="Arial, sans-serif" font-size="8.7" text-anchor="middle">Vehicles</text>

    <text x="391" y="392" fill="#ffffff" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" font-weight="700">3</text>
    <text x="391" y="404" fill="#eef2f7" font-family="Arial, sans-serif" font-size="8.7" text-anchor="middle">Partners</text>

    <text x="527" y="392" fill="#ffffff" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" font-weight="700">4.8/5</text>
    <text x="527" y="404" fill="#eef2f7" font-family="Arial, sans-serif" font-size="8.7" text-anchor="middle">Average Rating</text>
  </g>

  <rect y="423" width="800" height="27" fill="#edf2fb" fill-opacity="0.9"/>
</svg>
